                </div>
                
                <div class="footer__column">
                    <h4 class="footer__title">{{ trans('elements.footer.shop') }}</h4>
                    <ul class="footer__links">
                        {% for item in menu('footer-menu-1') %}
                        <li><a href="{{ item.url }}" class="footer__link">{{ item.name }}</a></li>
                        {% endfor %}
                    </ul>
                </div>
                
                <div class="footer__column">
                    <h4 class="footer__title">{{ trans('elements.footer.information') }}</h4>
                    <ul class="footer__links">
                        {% for item in menu('footer-menu-2') %}
                        <li><a href="{{ item.url }}" class="footer__link">{{ item.name }}</a></li>
                        {% endfor %}
                    </ul>
                </div>
                
                <div class="footer__column">
                    <h4 class="footer__title">{{ trans('elements.footer.customer_service') }}</h4>
                    <ul class="footer__links">
                        <li><a href="{{ store.contact_url }}" class="footer__link">{{ trans('elements.footer.contact_us') }}</a></li>
                        <li><a href="{{ store.shipping_url }}" class="footer__link">{{ trans('elements.footer.shipping_policy') }}</a></li>
                        <li><a href="{{ store.return_url }}" class="footer__link">{{ trans('elements.footer.return_policy') }}</a></li>
                        <li><a href="{{ store.faq_url }}" class="footer__link">{{ trans('elements.footer.faq') }}</a></li>
                    </ul>
                </div>
                
                {% if theme.settings.get('newsletter_enabled') %}
                <div class="footer__column footer__newsletter">
                    <h4 class="footer__title">{{ trans('elements.footer.newsletter') }}</h4>
                    <p class="footer__newsletter-text">{{ trans('elements.footer.newsletter_text') }}</p>
                    <form class="newsletter-form" action="{{ store.newsletter_url }}" method="post">
                        <input type="email" name="email" class="newsletter-form__input" placeholder="{{ trans('elements.common.email_placeholder') }}" required>
                        <button type="submit" class="newsletter-form__btn">{{ trans('elements.common.subscribe') }}</button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
    
    <div class="footer__bottom">
        <div class="container">
            <div class="footer__bottom-inner">
                <p class="footer__copyright">
                    &copy; {{ 'now'|date('Y') }} {{ store.name }}. {{ trans('elements.footer.all_rights_reserved') }}
                </p>
                <div class="footer__payments">
                    <img src="{{ 'images/payment-visa.svg' | asset }}" alt="Visa" class="footer__payment-icon">
                    <img src="{{ 'images/payment-mastercard.svg' | asset }}" alt="Mastercard" class="footer__payment-icon">
                    <img src="{{ 'images/payment-mada.svg' | asset }}" alt="Mada" class="footer__payment-icon">
                    <img src="{{ 'images/payment-apple-pay.svg' | asset }}" alt="Apple Pay" class="footer__payment-icon">
                </div>
            </div>
        </div>
    </div>
</footer>