{% extends 'layouts/master.twig' %}

{% block title %}{{ trans('elements.contact.title') }} - {{ store.name }}{% endblock %}

{% block content %}
<div class="section">
    <div class="container container--narrow">
        <div class="section-header">
            <h1 class="section-header__title">{{ trans('elements.contact.title') }}</h1>
            <div class="section-header__divider">
                <span class="section-header__line"></span>
                <span class="section-header__diamond"></span>
                <span class="section-header__line"></span>
            </div>
        </div>
        
        <div class="contact-page">
            <div class="contact-info">
                {% if store.address %}
                <div class="contact-info__item">
                    <h3 class="contact-info__title">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2"/>
                            <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        {{ trans('elements.contact.address') }}
                    </h3>
                    <p class="contact-info__text">{{ store.address }}</p>
                </div>
                {% endif %}
                
                {% if store.phone %}
                <div class="contact-info__item">
                    <h3 class="contact-info__title">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        {{ trans('elements.contact.phone') }}
                    </h3>
                    <p class="contact-info__text">
                        <a href="tel:{{ store.phone }}">{{ store.phone }}</a>
                    </p>
                </div>
                {% endif %}
                
                {% if store.email %}
                <div class="contact-info__item">
                    <h3 class="contact-info__title">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2"/>
                            <path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        {{ trans('elements.contact.email') }}
                    </h3>
                    <p class="contact-info__text">
                        <a href="mailto:{{ store.email }}">{{ store.email }}</a>
                    </p>
                </div>
                {% endif %}
                
                {% if store.working_hours %}
                <div class="contact-info__item">
                    <h3 class="contact-info__title">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                            <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        {{ trans('elements.contact.hours') }}
                    </h3>
                    <p class="contact-info__text">{{ store.working_hours }}</p>
                </div>
                {% endif %}
            </div>
            
            <form class="contact-form" action="{{ store.contact_url }}" method="post">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="contact-name">{{ trans('elements.contact.name') }}</label>
                        <input type="text" id="contact-name" name="name" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="contact-email">{{ trans('elements.contact.email') }}</label>
                        <input type="email" id="contact-email" name="email" class="form-input" required>
                    </div>
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="contact-phone">{{ trans('elements.contact.phone') }}</label>
                    <input type="tel" id="contact-phone" name="phone" class="form-input">
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="contact-subject">{{ trans('elements.contact.subject') }}</label>
                    <input type="text" id="contact-subject" name="subject" class="form-input">
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="contact-message">{{ trans('elements.contact.message') }}</label>
                    <textarea id="contact-message" name="message" class="form-textarea" rows="5" required></textarea>
                </div>
                
                <button type="submit" class="btn btn--primary btn--large">
                    {{ trans('elements.contact.send_message') }}
                </button>
            </form>
        </div>
    </div>
</div>

<style>
.contact-page {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 60px;
}

.contact-info__item {
    margin-bottom: 30px;
}

.contact-info__title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--secondary-color);
}

.contact-info__title svg {
    width: 24px;
    height: 24px;
    color: var(--primary-color);
}

.contact-info__text {
    color: var(--text-light);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
}

.contact-info__text a {
    color: var(--text-color);
    transition: color var(--transition-fast);
}

.contact-info__text a:hover {
    color: var(--primary-color);
}

.contact-form {
    background-color: var(--bg-light);
    padding: 40px;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

@media (max-width: 768px) {
    .contact-page {
        grid-template-columns: 1fr;
        gap: 40px;
    }
    
    .form-row {
        grid-template-columns: 1fr;
    }
    
    .contact-form {
        padding: 24px;
    }
}
</style>
{% endblock %}