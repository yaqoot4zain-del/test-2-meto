{% extends 'layouts/master.twig' %}

{% block title %}{{ product.name }} - {{ store.name }}{% endblock %}

{% block meta_description %}{{ product.description|striptags|slice(0, 160) }}{% endblock %}

{% block content %}
<div class="product-page">
    <div class="container">
        <nav class="breadcrumb">
            <a href="{{ store.url }}" class="breadcrumb__link">{{ trans('elements.common.home') }}</a>
            <span class="breadcrumb__separator">/</span>
            {% if product.category %}
            <a href="{{ product.category.url }}" class="breadcrumb__link">{{ product.category.name }}</a>
            <span class="breadcrumb__separator">/</span>
            {% endif %}
            <span class="breadcrumb__current">{{ product.name }}</span>
        </nav>
        
        <div class="product-page__grid">
            <div class="product-gallery">
                <div class="product-gallery__main">
                    <img src="{{ product.image ?? 'images/placeholder.jpg' | asset }}" alt="{{ product.name }}" id="product-main-image">
                </div>
                {% if product.images|length > 1 %}
                <div class="product-gallery__thumbnails">
                    {% for image in product.images %}
                    <button class="product-gallery__thumbnail {% if loop.first %}active{% endif %}" data-image="{{ image }}" aria-label="{{ trans('elements.product.view_image') }} {{ loop.index }}">
                        <img src="{{ image }}" alt="{{ product.name }} - {{ loop.index }}">
                    </button>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            
            <div class="product-info">
                {% if product.sku %}
                <p class="product-info__sku">{{ trans('elements.product.sku') }}: {{ product.sku }}</p>
                {% endif %}
                
                <h1 class="product-info__title">{{ product.name }}</h1>
                
                <div class="product-info__price">
                    {% if product.on_sale %}
                    <span class="product-info__price-current">{{ product.sale_price }}</span>
                    <span class="product-info__price-old">{{ product.regular_price }}</span>
                    {% else %}
                    <span>{{ product.price }}</span>
                    {% endif %}
                </div>
                
                {% if product.availability %}
                <p class="product-info__availability {% if product.in_stock %}in-stock{% else %}out-of-stock{% endif %}">
                    {% if product.in_stock %}
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {{ trans('elements.product.in_stock') }}
                    {% else %}
                    {{ trans('elements.product.out_of_stock') }}
                    {% endif %}
                </p>
                {% endif %}
                
                <div class="product-info__description">
                    {{ product.description|raw }}
                </div>
                
                {% if product.options|length > 0 %}
                <div class="product-options">
                    {% for option in product.options %}
                    <div class="product-option">
                        <label class="product-options__label">{{ option.name }}</label>
                        <div class="product-options__variants">
                            {% for value in option.values %}
                            <button class="product-options__variant {% if loop.first %}active{% endif %}" 
                                    data-option="{{ option.id }}" 
                                    data-value="{{ value }}">
                                {{ value }}
                            </button>
                            {% endfor %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
                
                <div class="product-quantity">
                    <label class="product-options__label">{{ trans('elements.product.quantity') }}</label>
                    <div class="quantity-selector">
                        <button class="quantity-selector__btn" data-action="decrease" aria-label="{{ trans('elements.common.decrease') }}">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/>
                            </svg>
                        </button>
                        <input type="number" class="quantity-selector__input" value="1" min="1" max="{{ product.max_quantity ?? 99 }}">
                        <button class="quantity-selector__btn" data-action="increase" aria-label="{{ trans('elements.common.increase') }}">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2"/>
                                <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/>
                            </svg>
                        </button>
                    </div>
                </div>
                
                <div class="product-actions">
                    <button class="btn btn--primary btn--large btn--full" data-add-to-cart="{{ product.id }}" {% if not product.in_stock %}disabled{% endif %}>
                        {% if product.in_stock %}
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="9" cy="21" r="1" stroke="currentColor" stroke-width="2"/>
                            <circle cx="20" cy="21" r="1" stroke="currentColor" stroke-width="2"/>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        {{ trans('elements.common.add_to_cart') }}
                        {% else %}
                        {{ trans('elements.product.out_of_stock') }}
                        {% endif %}
                    </button>
                    <button class="btn btn--outline btn--large" data-wishlist="{{ product.id }}" aria-label="{{ trans('elements.common.add_to_wishlist') }}">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="2"/>
                        </svg>
                    </button>
                </div>
                
                <div class="product-meta">
                    {% if product.category %}
                    <div class="product-meta__item">
                        <span class="product-meta__label">{{ trans('elements.product.category') }}:</span>
                        <a href="{{ product.category.url }}" class="product-meta__value">{{ product.category.name }}</a>
                    </div>
                    {% endif %}
                    {% if product.tags|length > 0 %}
                    <div class="product-meta__item">
                        <span class="product-meta__label">{{ trans('elements.product.tags') }}:</span>
                        <div class="product-meta__tags">
                            {% for tag in product.tags %}
                            <a href="{{ tag.url }}" class="product-meta__tag">{{ tag.name }}</a>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>
                
                <div class="product-share">
                    <span class="product-meta__label">{{ trans('elements.product.share') }}:</span>
                    <div class="product-share__links">
                        <a href="https://www.facebook.com/sharer/sharer.php?u={{ product.url|url_encode }}" class="product-share__link" target="_blank" rel="noopener" aria-label="Facebook">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                            </svg>
                        </a>
                        <a href="https://twitter.com/intent/tweet?url={{ product.url|url_encode }}&text={{ product.name|url_encode }}" class="product-share__link" target="_blank" rel="noopener" aria-label="Twitter">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                            </svg>
                        </a>
                        <a href="https://pinterest.com/pin/create/button/?url={{ product.url|url_encode }}&media={{ product.image|url_encode }}&description={{ product.name|url_encode }}" class="product-share__link" target="_blank" rel="noopener" aria-label="Pinterest">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.192 0 3.874-2.309 3.874-5.662 0-2.962-2.128-5.041-5.165-5.041-3.52 0-5.583 2.641-5.583 5.372 0 1.064.409 2.203.921 2.822.101.123.116.233.086.357-.094.388-.304 1.237-.345 1.409-.054.228-.179.276-.413.166-1.54-.717-2.501-2.968-2.501-4.771 0-3.887 2.824-7.457 8.134-7.457 4.277 0 7.601 3.049 7.601 7.131 0 4.258-2.687 7.688-6.413 7.688-1.253 0-2.43-.651-2.834-1.422l-.771 2.937c-.279 1.074-1.034 2.42-1.538 3.242C9.614 23.844 10.775 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
                            </svg>
                        </a>
                        <button class="product-share__link" data-copy-link="{{ product.url }}" aria-label="{{ trans('elements.common.copy_link') }}">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/>
                                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke="currentColor" stroke-width="2"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        {% if related_products|length > 0 %}
        <section class="section section--small">
            <div class="section-header">
                <h2 class="section-header__title">{{ trans('elements.product.related_products') }}</h2>
                <div class="section-header__divider">
                    <span class="section-header__line"></span>
                    <span class="section-header__diamond"></span>
                    <span class="section-header__line"></span>
                </div>
            </div>
            <div class="products-grid products-grid--4">
                {% for product in related_products %}
                <article class="product-card">
                    <div class="product-card__image-wrapper">
                        <a href="{{ product.url }}">
                            <img src="{{ product.image ?? 'images/placeholder.jpg' | asset }}" alt="{{ product.name }}" class="product-card__image">
                        </a>
                        <div class="product-card__actions">
                            <button class="product-card__action-btn" data-wishlist="{{ product.id }}" aria-label="{{ trans('elements.common.add_to_wishlist') }}">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="2"/>
                                </svg>
                            </button>
                            <button class="product-card__action-btn" data-add-to-cart="{{ product.id }}" aria-label="{{ trans('elements.common.add_to_cart') }}">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" stroke="currentColor" stroke-width="2"/>
                                    <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2"/>
                                    <path d="M16 10a4 4 0 0 1-8 0" stroke="currentColor" stroke-width="2"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="product-card__content">
                        <h3 class="product-card__title">
                            <a href="{{ product.url }}">{{ product.name }}</a>
                        </h3>
                        <div class="product-card__price">
                            <span class="product-card__price-current">{{ product.price }}</span>
                        </div>
                    </div>
                </article>
                {% endfor %}
            </div>
        </section>
        {% endif %}
    </div>
</div>
{% endblock %}