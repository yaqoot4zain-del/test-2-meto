{% extends 'layouts/master.twig' %}

{% block title %}{{ products.title ?? trans('elements.product.products') }} - {{ store.name }}{% endblock %}

{% block content %}
<div class="section">
    <div class="container">
        <nav class="breadcrumb">
            <a href="{{ store.url }}" class="breadcrumb__link">{{ trans('elements.common.home') }}</a>
            <span class="breadcrumb__separator">/</span>
            <span class="breadcrumb__current">{{ products.title ?? trans('elements.product.products') }}</span>
        </nav>
        
        <div class="section-header">
            {% if products.subtitle %}
            <p class="section-header__subtitle">{{ products.subtitle }}</p>
            {% endif %}
            <h1 class="section-header__title">{{ products.title ?? trans('elements.product.products') }}</h1>
            <div class="section-header__divider">
                <span class="section-header__line"></span>
                <span class="section-header__diamond"></span>
                <span class="section-header__line"></span>
            </div>
        </div>
        
        <div class="products-filter">
            <div class="products-filter__count">
                {{ trans('elements.product.showing') }} <strong>{{ products.from }}-{{ products.to }}</strong> {{ trans('elements.product.of') }} <strong>{{ products.total }}</strong> {{ trans('elements.product.products') }}
            </div>
            <div class="products-filter__sort">
                <label class="products-filter__label">{{ trans('elements.product.sort_by') }}:</label>
                <select class="form-select products-filter__select" id="sort-select">
                    <option value="default" {% if sort == 'default' %}selected{% endif %}>{{ trans('elements.product.default_sort') }}</option>
                    <option value="price-low" {% if sort == 'price-low' %}selected{% endif %}>{{ trans('elements.product.price_low_high') }}</option>
                    <option value="price-high" {% if sort == 'price-high' %}selected{% endif %}>{{ trans('elements.product.price_high_low') }}</option>
                    <option value="newest" {% if sort == 'newest' %}selected{% endif %}>{{ trans('elements.product.newest') }}</option>
                    <option value="popular" {% if sort == 'popular' %}selected{% endif %}>{{ trans('elements.product.popular') }}</option>
                </select>
            </div>
        </div>
        
        {% if products|length > 0 %}
        <div class="products-grid">
            {% for product in products %}
            <article class="product-card">
                <div class="product-card__image-wrapper">
                    <a href="{{ product.url }}">
                        <img src="{{ product.image ?? 'images/placeholder.jpg' | asset }}" alt="{{ product.name }}" class="product-card__image">
                    </a>
                    {% if product.is_new %}
                    <span class="product-card__badge product-card__badge--new">{{ trans('elements.product.new') }}</span>
                    {% elseif product.on_sale %}
                    <span class="product-card__badge product-card__badge--sale">{{ trans('elements.product.sale') }}</span>
                    {% endif %}
                    <div class="product-card__actions">
                        <button class="product-card__action-btn" data-wishlist="{{ product.id }}" aria-label="{{ trans('elements.common.add_to_wishlist') }}">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="2"/>
                            </svg>
                        </button>
                        <button class="product-card__action-btn" data-quick-view="{{ product.id }}" aria-label="{{ trans('elements.common.quick_view') }}">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2"/>
                                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
                            </svg>
                        </button>
                        <button class="product-card__action-btn" data-add-to-cart="{{ product.id }}" aria-label="{{ trans('elements.common.add_to_cart') }}">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" stroke="currentColor" stroke-width="2"/>
                                <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2"/>
                                <path d="M16 10a4 4 0 0 1-8 0" stroke="currentColor" stroke-width="2"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="product-card__content">
                    <h3 class="product-card__title">
                        <a href="{{ product.url }}">{{ product.name }}</a>
                    </h3>
                    <div class="product-card__price">
                        {% if product.on_sale %}
                        <span class="product-card__price-current">{{ product.sale_price }}</span>
                        <span class="product-card__price-old">{{ product.regular_price }}</span>
                        {% else %}
                        <span class="product-card__price-current">{{ product.price }}</span>
                        {% endif %}
                    </div>
                </div>
            </article>
            {% endfor %}
        </div>
        
        {% if products.pagination.pages > 1 %}
        <nav class="pagination">
            {% if products.pagination.current > 1 %}
            <a href="{{ products.pagination.prev_url }}" class="pagination__item pagination__item--prev">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {{ trans('elements.pagination.prev') }}
            </a>
            {% endif %}
            
            {% for page in 1..products.pagination.pages %}
            <a href="{{ products.pagination.get_url(page) }}" class="pagination__item {% if page == products.pagination.current %}active{% endif %}">
                {{ page }}
            </a>
            {% endfor %}
            
            {% if products.pagination.current < products.pagination.pages %}
            <a href="{{ products.pagination.next_url }}" class="pagination__item pagination__item--next">
                {{ trans('elements.pagination.next') }}
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
            {% endif %}
        </nav>
        {% endif %}
        {% else %}
        <div class="products-empty">
            <p>{{ trans('elements.product.no_products') }}</p>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}