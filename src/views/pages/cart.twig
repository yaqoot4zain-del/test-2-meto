{% extends 'layouts/master.twig' %}

{% block title %}{{ trans('elements.cart.shopping_cart') }} - {{ store.name }}{% endblock %}

{% block content %}
<main class="cart-page">
    <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 40px 20px;">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" style="padding: 20px 0; font-size: 13px; color: #666;">
            <a href="{{ store.url }}" style="color: #666; text-decoration: none;">{{ trans('elements.common.home') }}</a>
            <span style="margin: 0 8px;">/</span>
            <span style="color: var(--gold-primary);">{{ trans('elements.cart.shopping_cart') }}</span>
        </nav>

        <h1 style="font-family: 'Playfair Display', serif; font-size: 36px; margin-bottom: 40px;">Shopping Cart</h1>

        {% if cart.items|length > 0 %}
        <div class="cart-content" style="display: grid; grid-template-columns: 1fr 380px; gap: 40px;">
            <!-- Cart Items -->
            <div class="cart-items">
                <div class="cart-header" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; padding: 16px 0; border-bottom: 1px solid #e5e5e5; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; color: #666;">
                    <span>Product</span>
                    <span style="text-align: center;">Price</span>
                    <span style="text-align: center;">Quantity</span>
                    <span style="text-align: right;">Total</span>
                </div>

                {% for item in cart.items %}
                <div class="cart-item" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; padding: 24px 0; border-bottom: 1px solid #f0f0f0; align-items: center;">
                    <div class="cart-item__product" style="display: flex; gap: 20px; align-items: center;">
                        <div class="cart-item__image" style="width: 100px; height: 100px; background: #F5F3EF; border-radius: 8px; overflow: hidden;">
                            <img src="{{ item.image }}" alt="{{ item.name }}" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div class="cart-item__details">
                            <h3 style="font-size: 16px; font-weight: 500; margin-bottom: 8px;"><a href="{{ item.url }}" style="color: var(--black); text-decoration: none;">{{ item.name }}</a></h3>
                            {% if item.options %}
                            <p style="font-size: 13px; color: #666;">{{ item.options }}</p>
                            {% endif %}
                            <button class="remove-item" data-id="{{ item.id }}" style="font-size: 13px; color: #999; background: none; border: none; cursor: pointer; margin-top: 8px; padding: 0;">Remove</button>
                        </div>
                    </div>
                    <div class="cart-item__price" style="text-align: center; font-size: 16px; color: var(--black);">{{ item.price }}</div>
                    <div class="cart-item__quantity" style="text-align: center;">
                        <div class="quantity-input" style="display: inline-flex; align-items: center; border: 1px solid #e5e5e5; border-radius: 8px;">
                            <button class="qty-btn" style="width: 36px; height: 36px; border: none; background: none; cursor: pointer; font-size: 18px;">−</button>
                            <input type="number" value="{{ item.quantity }}" min="1" style="width: 50px; height: 36px; border: none; text-align: center; font-size: 14px;">
                            <button class="qty-btn" style="width: 36px; height: 36px; border: none; background: none; cursor: pointer; font-size: 18px;">+</button>
                        </div>
                    </div>
                    <div class="cart-item__total" style="text-align: right; font-size: 16px; font-weight: 500; color: var(--black);">{{ item.total }}</div>
                </div>
                {% endfor %}
            </div>

            <!-- Cart Summary -->
            <div class="cart-summary" style="background: #FAF9F6; padding: 30px; border-radius: 12px; height: fit-content;">
                <h2 style="font-family: 'Playfair Display', serif; font-size: 24px; margin-bottom: 24px;">Order Summary</h2>
                
                <div class="summary-row" style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #e5e5e5;">
                    <span style="color: #666;">Subtotal</span>
                    <span style="font-weight: 500;">{{ cart.subtotal }}</span>
                </div>
                
                {% if cart.discount %}
                <div class="summary-row" style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #e5e5e5;">
                    <span style="color: #666;">Discount</span>
                    <span style="color: #D0021B;">-{{ cart.discount }}</span>
                </div>
                {% endif %}
                
                <div class="summary-row" style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #e5e5e5;">
                    <span style="color: #666;">Shipping</span>
                    <span style="font-weight: 500;">{{ cart.shipping ?? 'Calculated at checkout' }}</span>
                </div>
                
                <div class="summary-total" style="display: flex; justify-content: space-between; padding: 20px 0; font-size: 20px; font-weight: 600;">
                    <span>Total</span>
                    <span style="color: var(--gold-primary);">{{ cart.total }}</span>
                </div>

                <!-- Promo Code -->
                <div class="promo-code" style="margin-bottom: 20px;">
                    <label style="font-size: 14px; color: #666; margin-bottom: 8px; display: block;">Promo Code</label>
                    <div style="display: flex; gap: 8px;">
                        <input type="text" placeholder="Enter code" style="flex: 1; padding: 12px 16px; border: 1px solid #e5e5e5; border-radius: 8px; font-size: 14px;">
                        <button style="padding: 12px 20px; background: var(--black); color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 14px;">Apply</button>
                    </div>
                </div>

                <a href="{{ store.checkout_url }}" class="btn btn--gold" style="display: block; text-align: center; margin-bottom: 16px; padding: 18px;">Proceed to Checkout</a>
                
                <a href="{{ store.products_url }}" style="display: block; text-align: center; color: #666; text-decoration: none; font-size: 14px;">Continue Shopping</a>
            </div>
        </div>

        {% else %}
        <!-- Empty Cart -->
        <div class="empty-cart" style="text-align: center; padding: 80px 0;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" style="width: 80px; height: 80px; margin-bottom: 24px;">
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                <line x1="3" y1="6" x2="21" y2="6"/>
                <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            <h2 style="font-family: 'Playfair Display', serif; font-size: 28px; margin-bottom: 16px;">Your Cart is Empty</h2>
            <p style="color: #666; margin-bottom: 32px;">Looks like you haven't added anything to your cart yet.</p>
            <a href="{{ store.products_url }}" class="btn btn--gold" style="display: inline-block; padding: 16px 48px;">Start Shopping</a>
        </div>
        {% endif %}

        <!-- Features -->
        <div class="cart-features" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-top: 60px; padding-top: 60px; border-top: 1px solid #e5e5e5;">
            <div class="feature" style="text-align: center;">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold-primary)" stroke-width="1.5" style="width: 48px; height: 48px; margin-bottom: 16px;">
                    <rect x="1" y="3" width="15" height="13" rx="2"/>
                    <path d="M16 8h2a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-1"/>
                </svg>
                <h3 style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">Secure Payment</h3>
                <p style="font-size: 14px; color: #666;">100% secure payment with SSL encryption</p>
            </div>
            <div class="feature" style="text-align: center;">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold-primary)" stroke-width="1.5" style="width: 48px; height: 48px; margin-bottom: 16px;">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
                <h3 style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">Fast Delivery</h3>
                <p style="font-size: 14px; color: #666;">Free shipping on orders over 500 SAR</p>
            </div>
            <div class="feature" style="text-align: center;">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold-primary)" stroke-width="1.5" style="width: 48px; height: 48px; margin-bottom: 16px;">
                    <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                    <path d="M3 3v5h5"/>
                </svg>
                <h3 style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">Easy Returns</h3>
                <p style="font-size: 14px; color: #666;">30-day return policy for all items</p>
            </div>
        </div>
    </div>
</main>

<style>
@media (max-width: 992px) {
    .cart-content {
        grid-template-columns: 1fr !important;
    }
    .cart-header {
        display: none !important;
    }
    .cart-item {
        grid-template-columns: 1fr !important;
        gap: 16px;
    }
    .cart-item__product {
        flex-direction: column;
        align-items: flex-start !important;
    }
    .cart-features {
        grid-template-columns: 1fr !important;
    }
}
</style>
{% endblock %}