{% extends 'layouts/master.twig' %}

{% block title %}{{ trans('elements.cart.title') }} - {{ store.name }}{% endblock %}

{% block content %}
<div class="cart-page section">
    <div class="container">
        <h1 class="cart-page__title">{{ trans('elements.cart.title') }}</h1>
        
        {% if cart.items|length > 0 %}
        <div class="cart-page__grid">
            <div class="cart-page__items">
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>{{ trans('elements.cart.product') }}</th>
                            <th>{{ trans('elements.cart.price') }}</th>
                            <th>{{ trans('elements.cart.quantity') }}</th>
                            <th>{{ trans('elements.cart.total') }}</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in cart.items %}
                        <tr data-cart-item="{{ item.id }}">
                            <td>
                                <div class="cart-table__product">
                                    <a href="{{ item.product.url }}">
                                        <img src="{{ item.product.image ?? 'images/placeholder.jpg' | asset }}" alt="{{ item.product.name }}" class="cart-table__image">
                                    </a>
                                    <div>
                                        <a href="{{ item.product.url }}" class="cart-table__name">{{ item.product.name }}</a>
                                        {% if item.options %}
                                        <div class="cart-table__options">
                                            {% for option in item.options %}
                                            <span>{{ option.name }}: {{ option.value }}</span>
                                            {% endfor %}
                                        </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td data-item-price="{{ item.price }}">{{ item.price }}</td>
                            <td>
                                <div class="quantity-selector">
                                    <button class="quantity-selector__btn" data-action="decrease" data-cart-item="{{ item.id }}" aria-label="{{ trans('elements.common.decrease') }}">
                                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/>
                                        </svg>
                                    </button>
                                    <input type="number" class="quantity-selector__input" value="{{ item.quantity }}" min="1" max="{{ item.product.max_quantity ?? 99 }}" data-cart-item="{{ item.id }}">
                                    <button class="quantity-selector__btn" data-action="increase" data-cart-item="{{ item.id }}" aria-label="{{ trans('elements.common.increase') }}">
                                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2"/>
                                            <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                            <td data-item-total="{{ item.total }}">{{ item.total }}</td>
                            <td>
                                <button class="cart-table__remove" data-remove-item="{{ item.id }}" aria-label="{{ trans('elements.common.remove') }}">
                                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            <div class="cart-summary">
                <div class="cart-summary__row">
                    <span>{{ trans('elements.cart.subtotal') }}</span>
                    <span data-cart-subtotal>{{ cart.subtotal }}</span>
                </div>
                {% if cart.discount %}
                <div class="cart-summary__row">
                    <span>{{ trans('elements.cart.discount') }}</span>
                    <span data-cart-discount>-{{ cart.discount }}</span>
                </div>
                {% endif %}
                <div class="cart-summary__row cart-summary__total">
                    <span>{{ trans('elements.cart.total') }}</span>
                    <span data-cart-total>{{ cart.total }}</span>
                </div>
                
                {% if coupon_form %}
                <form class="cart-coupon" action="{{ coupon_form.action }}" method="post">
                    <label class="cart-coupon__label">{{ trans('elements.cart.coupon') }}</label>
                    <div class="cart-coupon__input">
                        <input type="text" name="coupon_code" class="form-input" placeholder="{{ trans('elements.cart.coupon_placeholder') }}">
                        <button type="submit" class="btn btn--outline">{{ trans('elements.cart.apply_coupon') }}</button>
                    </div>
                </form>
                {% endif %}
                
                <a href="{{ store.checkout_url }}" class="btn btn--primary btn--large cart-summary__btn">
                    {{ trans('elements.cart.checkout') }}
                </a>
                
                <div class="cart-summary__shipping">
                    <p>{{ trans('elements.cart.shipping_calculated') }}</p>
                </div>
                
                <div class="cart-summary__secure">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="2"/>
                        <path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="2"/>
                    </svg>
                    <span>{{ trans('elements.cart.secure_checkout') }}</span>
                </div>
            </div>
        </div>
        {% else %}
        <div class="cart-empty">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="21" r="1" stroke="currentColor" stroke-width="2"/>
                <circle cx="20" cy="21" r="1" stroke="currentColor" stroke-width="2"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" stroke="currentColor" stroke-width="2"/>
            </svg>
            <h2>{{ trans('elements.cart.empty_title') }}</h2>
            <p>{{ trans('elements.cart.empty_text') }}</p>
            <a href="{{ store.products_url }}" class="btn btn--primary btn--large">
                {{ trans('elements.cart.continue_shopping') }}
            </a>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}