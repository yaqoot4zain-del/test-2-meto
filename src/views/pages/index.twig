{% extends 'layouts/master.twig' %}

{% block content %}
{# Hero Section with Demo Content #}
<section class="hero">
    <div class="hero__slide">
        <div class="hero__image-wrapper" style="background: linear-gradient(135deg, #B8860B 0%, #D4AF37 50%, #1a1a1a 100%); min-height: 70vh; display: flex; align-items: center; justify-content: center;">
        </div>
        <div class="hero__overlay"></div>
        <div class="hero__content container" style="text-align: center; color: white;">
            <p class="hero__subtitle" style="font-size: 14px; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 16px;">NEW COLLECTION</p>
            <h1 class="hero__title" style="font-size: 56px; font-weight: 500; margin-bottom: 16px;">Elegant Jewelry</h1>
            <p class="hero__text" style="font-size: 18px; margin-bottom: 32px;">Discover our exquisite collection of fine jewelry</p>
            <a href="/collections/all" class="btn btn--gold btn--large" style="display: inline-block; padding: 16px 48px; background: #B8860B; color: white; text-decoration: none; text-transform: uppercase; letter-spacing: 1px;">
                SHOP NOW
            </a>
        </div>
    </div>
</section>

{# Collections Navigation #}
<section class="collections-nav" style="padding: 20px 0; background: white; border-bottom: 1px solid #f0f0f0;">
    <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
        <nav class="collections-nav__inner" style="display: flex; justify-content: center; gap: 40px;">
            <a href="/collections/all" class="collections-nav__link" style="font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #333; text-decoration: none;">All</a>
            <a href="/collections/rings" class="collections-nav__link" style="font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #333; text-decoration: none;">Rings</a>
            <a href="/collections/earrings" class="collections-nav__link" style="font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #333; text-decoration: none;">Earrings</a>
            <a href="/collections/bracelets" class="collections-nav__link" style="font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #333; text-decoration: none;">Bracelets</a>
            <a href="/collections/necklaces" class="collections-nav__link" style="font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #333; text-decoration: none;">Necklaces</a>
        </nav>
    </div>
</section>

{# Bestsellers Section #}
<section class="section" style="padding: 80px 0; background: #FAF9F6;">
    <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
        <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h2 class="section-title" style="font-size: 28px; font-family: 'Playfair Display', serif;">LuluOro Bestsellers</h2>
            <a href="/collections/lo-iconics" class="section-link" style="font-size: 14px; color: #B8860B; text-decoration: underline;">View all</a>
        </div>
        <div class="products-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px;">
            {# Demo Product 1 #}
            <div class="product-card" style="text-align: center;">
                <div class="product-card__image-wrapper" style="position: relative; aspect-ratio: 1; background: #F5F3EF; margin-bottom: 16px; overflow: hidden;">
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(45deg, #B8860B, #D4AF37);">
                        <span style="color: white; font-size: 48px;">💎</span>
                    </div>
                </div>
                <h3 class="product-card__title" style="font-size: 14px; margin-bottom: 8px;">ARCH NECKLACE GOLD</h3>
                <p class="product-card__price" style="font-size: 14px; color: #666;">630.00 SAR</p>
            </div>
            {# Demo Product 2 #}
            <div class="product-card" style="text-align: center;">
                <div class="product-card__image-wrapper" style="position: relative; aspect-ratio: 1; background: #F5F3EF; margin-bottom: 16px; overflow: hidden;">
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(45deg, #1a1a1a, #333);">
                        <span style="color: #D4AF37; font-size: 48px;">💍</span>
                    </div>
                </div>
                <h3 class="product-card__title" style="font-size: 14px; margin-bottom: 8px;">PALM GARDEN EARRINGS</h3>
                <p class="product-card__price" style="font-size: 14px; color: #666;">590.00 SAR</p>
            </div>
            {# Demo Product 3 #}
            <div class="product-card" style="text-align: center;">
                <div class="product-card__image-wrapper" style="position: relative; aspect-ratio: 1; background: #F5F3EF; margin-bottom: 16px; overflow: hidden;">
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(45deg, #B8860B, #8B6914);">
                        <span style="color: white; font-size: 48px;">🌙</span>
                    </div>
                </div>
                <h3 class="product-card__title" style="font-size: 14px; margin-bottom: 8px;">NIGHT SKY NECKLACE</h3>
                <p class="product-card__price" style="font-size: 14px; color: #666;">690.00 SAR</p>
            </div>
            {# Demo Product 4 #}
            <div class="product-card" style="text-align: center;">
                <div class="product-card__image-wrapper" style="position: relative; aspect-ratio: 1; background: #F5F3EF; margin-bottom: 16px; overflow: hidden;">
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(45deg, #D4AF37, #B8860B);">
                        <span style="color: white; font-size: 48px;">✨</span>
                    </div>
                </div>
                <h3 class="product-card__title" style="font-size: 14px; margin-bottom: 8px;">DATES TEXTURE DROP STUDS</h3>
                <p class="product-card__price" style="font-size: 14px; color: #666;">430.00 SAR</p>
            </div>
        </div>
    </div>
</section>

{# New Arrivals Section #}
<section class="section" style="padding: 80px 0; background: white;">
    <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
        <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h2 class="section-title" style="font-size: 28px; font-family: 'Playfair Display', serif;">New Arrivals</h2>
            <a href="/collections/new" class="section-link" style="font-size: 14px; color: #B8860B; text-decoration: underline;">View all</a>
        </div>
        <div class="products-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px;">
            <div class="product-card" style="text-align: center;">
                <div class="product-card__image-wrapper" style="position: relative; aspect-ratio: 1; background: #F5F3EF; margin-bottom: 16px; overflow: hidden;">
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #C0C0C0, #E8E8E8);">
                        <span style="color: #333; font-size: 48px;">🌙</span>
                    </div>
                </div>
                <h3 class="product-card__title" style="font-size: 14px; margin-bottom: 8px;">SILVER MOON CHARMS EARRINGS</h3>
                <p class="product-card__price" style="font-size: 14px; color: #666;">530.00 SAR</p>
            </div>
            <div class="product-card" style="text-align: center;">
                <div class="product-card__image-wrapper" style="position: relative; aspect-ratio: 1; background: #F5F3EF; margin-bottom: 16px; overflow: hidden;">
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #C0C0C0, #A9A9A9);">
                        <span style="color: white; font-size: 48px;">💎</span>
                    </div>
                </div>
                <h3 class="product-card__title" style="font-size: 14px; margin-bottom: 8px;">SWIRL RING IN SILVER</h3>
                <p class="product-card__price" style="font-size: 14px; color: #666;">430.00 SAR</p>
            </div>
            <div class="product-card" style="text-align: center;">
                <div class="product-card__image-wrapper" style="position: relative; aspect-ratio: 1; background: #F5F3EF; margin-bottom: 16px; overflow: hidden;">
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #B8860B, #D4AF37);">
                        <span style="color: white; font-size: 48px;">🌴</span>
                    </div>
                </div>
                <h3 class="product-card__title" style="font-size: 14px; margin-bottom: 8px;">PALM TREE EARRINGS - SILVER</h3>
                <p class="product-card__price" style="font-size: 14px; color: #666;">470.00 SAR</p>
            </div>
            <div class="product-card" style="text-align: center;">
                <div class="product-card__image-wrapper" style="position: relative; aspect-ratio: 1; background: #F5F3EF; margin-bottom: 16px; overflow: hidden;">
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #1a1a1a, #333);">
                        <span style="color: #D4AF37; font-size: 48px;">✨</span>
                    </div>
                </div>
                <h3 class="product-card__title" style="font-size: 14px; margin-bottom: 8px;">HILAL CHOCKER NECKLACE</h3>
                <p class="product-card__price" style="font-size: 14px; color: #666;">470.00 SAR</p>
            </div>
        </div>
    </div>
</section>

{# Brand Story Section #}
<section class="brand-story" style="padding: 100px 0; background: #FAF9F6;">
    <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
        <div class="brand-story__inner" style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">
            <div class="brand-story__image" style="aspect-ratio: 4/5; background: linear-gradient(135deg, #B8860B, #D4AF37); display: flex; align-items: center; justify-content: center;">
                <span style="font-size: 120px; color: white;">💎</span>
            </div>
            <div class="brand-story__content" style="padding: 40px;">
                <h2 class="brand-story__title" style="font-size: 36px; font-family: 'Playfair Display', serif; margin-bottom: 24px;">Our Story</h2>
                <p class="brand-story__text" style="font-size: 16px; line-height: 1.8; color: #666; margin-bottom: 32px;">
                    At LuluOro, we believe that jewelry should be as unique as the person wearing it. Each piece is crafted with precision and passion, combining traditional artistry with contemporary design. Our collections are inspired by the beauty of nature and the elegance of timeless craftsmanship.
                </p>
                <a href="/pages/about" class="btn btn--gold" style="display: inline-block; padding: 12px 32px; background: #B8860B; color: white; text-decoration: none; text-transform: uppercase; letter-spacing: 1px;">Learn More</a>
            </div>
        </div>
    </div>
</section>

{# Shop the Looks Section #}
<section class="shop-looks" style="padding: 80px 0; background: white;">
    <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
        <h2 class="section-title section-title--center" style="font-size: 28px; font-family: 'Playfair Display', serif; text-align: center; margin-bottom: 40px;">Shop the Looks</h2>
        <div class="looks-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px;">
            <a href="/pages/night-sky-mix-match" class="look-item" style="text-align: center; text-decoration: none;">
                <div style="aspect-ratio: 3/4; background: linear-gradient(135deg, #1a1a1a, #333); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                    <span style="font-size: 64px;">🌙✨</span>
                </div>
                <h3 class="look-item__title" style="font-size: 16px; color: #1a1a1a;">Night Sky Mix & Match</h3>
            </a>
            <a href="/pages/gold-and-malachite-statements" class="look-item" style="text-align: center; text-decoration: none;">
                <div style="aspect-ratio: 3/4; background: linear-gradient(135deg, #B8860B, #D4AF37); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                    <span style="font-size: 64px;">💚💫</span>
                </div>
                <h3 class="look-item__title" style="font-size: 16px; color: #1a1a1a;">Gold and Malachite Statements</h3>
            </a>
            <a href="/pages/meaningful-accents" class="look-item" style="text-align: center; text-decoration: none;">
                <div style="aspect-ratio: 3/4; background: linear-gradient(135deg, #C0C0C0, #E8E8E8); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                    <span style="font-size: 64px;">💎🌿</span>
                </div>
                <h3 class="look-item__title" style="font-size: 16px; color: #1a1a1a;">Meaningful Accents</h3>
            </a>
        </div>
    </div>
</section>

{# Instagram Feed Placeholder #}
<section class="instagram-feed" style="padding: 80px 0; background: #FAF9F6;">
    <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
        <h2 class="section-title section-title--center" style="font-size: 28px; font-family: 'Playfair Display', serif; text-align: center; margin-bottom: 40px;">Follow Us on Instagram</h2>
        <div class="instagram-grid" style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 15px;">
            {% for i in 1..6 %}
            <div class="instagram-item" style="aspect-ratio: 1; background: linear-gradient(45deg, #B8860B, #D4AF37); display: flex; align-items: center; justify-content: center;">
                <span style="font-size: 32px; color: white;">📷</span>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{{ content_for('home') }}
{% endblock %}